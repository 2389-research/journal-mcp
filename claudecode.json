{
  "name": "private-journal-mcp",
  "displayName": "Private Journal",
  "version": "1.4.0",
  "description": "A comprehensive MCP server that provides Claude with private journaling, semantic search, resources, and guided prompts for reflection and learning",
  "author": "Jesse Vincent <jesse@fsck.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/2389-research/journal-mcp"
  },
  "mcp": {
    "type": "stdio",
    "command": "node",
    "args": ["dist/index.js"]
  },
  "capabilities": {
    "tools": [
      "process_thoughts",
      "search_journal",
      "read_journal_entry",
      "list_recent_entries"
    ],
    "resources": true,
    "prompts": true
  },
  "keywords": [
    "journal",
    "mcp",
    "private",
    "semantic-search",
    "reflection",
    "learning"
  ],
  "license": "MIT"
}
